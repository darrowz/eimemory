# Copy to /etc/eimemory/governance.env with mode 0600.
# This default adapter reuses the operator's OpenClaw provider/model/fallback configuration.
EIMEMORY_PROMPT_SAFETY_COMMAND='["/opt/eimemory/current/.venv/bin/python","-m","eimemory.governance.prompt_safety_openclaw"]'
EIMEMORY_OPENCLAW_BIN=/home/USER/.local/bin/openclaw
# Leave blank to use OpenClaw's configured default model and fallback chain.
EIMEMORY_PROMPT_SAFETY_MODEL=
EIMEMORY_PROMPT_SAFETY_TIMEOUT_SECONDS=180
EIMEMORY_PROMPT_SAFETY_MAX_ATTEMPTS=2
EIMEMORY_PROMPT_SAFETY_PROMPT_FILES='["/home/USER/.openclaw/workspace/AGENTS.md","/home/USER/.openclaw/workspace/SOUL.md"]'
# Optional enhancement path: source selection uses this model, then deterministically falls back on any LLM error.
EIMEMORY_LLM_COMMAND='["/opt/eimemory/current/.venv/bin/python","-m","eimemory.llm.openclaw_adapter"]'
EIMEMORY_LLM_MODEL=
EIMEMORY_LLM_TIMEOUT_SECONDS=90
# Alternative: point EIMEMORY_PROMPT_SAFETY_COMMAND at prompt_safety_remote and configure
# EIMEMORY_PROMPT_SAFETY_BASE_URL, EIMEMORY_PROMPT_SAFETY_API_KEY, and EIMEMORY_PROMPT_SAFETY_MODEL.
