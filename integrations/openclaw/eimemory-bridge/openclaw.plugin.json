{
  "id": "eimemory-bridge",
  "name": "eimemory-bridge",
  "version": "0.1.0",
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook"
    ]
  },
  "hooks": [
    "message_received",
    "before_prompt_build",
    "agent_end",
    "message_sent",
    "session_end",
    "before_agent_finalize",
    "before_tool_call",
    "after_tool_call"
  ],
  "contracts": {
    "tools": [
      "eimemory_bridge_status",
      "memory_e2e_check"
    ]
  },
  "description": "Bridges OpenClaw lifecycle hooks into the local eimemory runtime.",
  "configSchema": {
    "type": "object",
    "properties": {},
    "additionalProperties": false
  }
}
