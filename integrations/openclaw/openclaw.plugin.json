{
  "id": "eimemory-bridge",
  "name": "eimemory-bridge",
  "version": "0.1.0",
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook"
    ]
  },
  "hooks": [
    "message_received",
    "before_prompt_build",
    "agent_end",
    "session_end",
    "before_agent_finalize",
    "before_tool_call"
  ],
  "contracts": {
    "tools": [
      "eimemory_bridge_status",
      "memory_e2e_check"
    ]
  },
  "main": "./eimemory-bridge/index.js",
  "displayName": "eimemory Bridge",
  "description": "OpenClaw bridge plugin that forwards lifecycle hooks into the local eimemory runtime.",
  "configSchema": {
    "type": "object",
    "properties": {}
  }
}
